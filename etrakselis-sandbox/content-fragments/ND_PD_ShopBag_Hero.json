    "content": "<div class=\"acr-fragment is-locked has-html-params\" data-fragment-id=\"ajo:fc52e944-6c9c-410d-b300-e5f646c152a1\"><!--[if gte mso 9]><style acrite-mso-css=\"true\">.image-container div {  display: block;}.structure__table td {  padding: 0;  border: none;}.button-container {  border: none !important;  padding: 0 !important;  margin: 0 !important;  line-height: normal !important;}.acr-component, .acr-tmp-component {  margin: 0 !important;  border: none !important;}.acr-fragment {  margin: 0 !important;  border: none !important;}</style><![endif]--><div class=\"acr-fragment acr-tmp-component\" data-tmp-component-id=\"text\" data-contenteditable=\"false\"><div class=\"text-container\" data-contenteditable=\"true\"><p style=\"font-family:sans-serif;font-size:40px;line-height:44px;font-weight:bold;color:#000001;margin:0;\">Back in stock&ndash;</p><p style=\"font-family:sans-serif;font-size:40px;line-height:44px;font-weight:bold;color:#000001;margin:0;\">these deals won&rsquo;t last!</p></div></div><div class=\"acr-fragment acr-tmp-component\" data-tmp-component-id=\"html\" data-contenteditable=\"false\">{{!-- ===== Global variables: UTM link params (utm_campaign derived from the email name) ===== --}}\n{% let emailName = \"n_shopbag_pd\" %}\n{% let utmLinkParams = concat(\"utm_source=N_triggered_bc&utm_medium=email&utm_channel=email_trig_ret_p&utm_campaign=\", concat(emailName, \"&utm_term=789708&utm_content=\")) %}\n{{!-- ===== Price-drop trigger map (SKU -> \"sale|was\") from the event payload ===== --}}\n{% let priceMap = context.journey.events.`408257574`._nordstrom.productTrigger.priceDropSKUs %}\n{% let skuList = keys(priceMap) %}\n{{!-- Pass 1: pick the hero = dropped SKU with the highest product-table sellingRetailPrice (a map cannot be topN-sorted, so track the max) --}}\n{% let bestSku = \"\" %}\n{% let bestPrice = -1.0 %}\n{{#each skuList as |sku|}}\n{{datasetLookup datasetId=\"6a46945945b281e561cf5e27\" id=sku result=\"cand\" required=false}}\n{%#if isNotNull(cand) %}\n{{!-- Eligibility: skip deleted, non-shippable, or out-of-stock SKUs --}}\n{% let candDeleted = cand._acssandboxustwo.nordstrom.productDetails.isDeleted %}\n{% let candShip = cand._acssandboxustwo.nordstrom.productDetails.isShipAvailable %}\n{% let candQty = cand._acssandboxustwo.nordstrom.productDetails.availableQuantity + 0.0 %}\n{%#if candDeleted %}{%else%}{%#if candShip %}{%#if candQty > 0.0 %}\n{% let candPrice = cand._acssandboxustwo.nordstrom.productDetails.sellingRetailPrice + 0.0 %}\n{%#if candPrice > bestPrice %}\n{% let bestPrice = candPrice %}\n{% let bestSku = sku %}\n{%/if%}\n{%/if%}{%/if%}{%/if%}\n{%/if%}\n{{/each}}\n{{!-- Pass 2: render the winning hero product; display price comes from the payload pipe value --}}\n{%#if isNotEmpty(bestSku) %}\n{{datasetLookup datasetId=\"6a46945945b281e561cf5e27\" id=bestSku result=\"hero\" required=false}}\n{%#if isNotNull(hero) %}\n{% let pair = get(priceMap, bestSku) %}\n{% let salePrice = replace(pair, \"\\\\|.*\", \"\") %}\n{% let wasPrice = replace(pair, \".*\\\\|\", \"\") %}\n{% let clickUrl = hero._acssandboxustwo.nordstrom.productDetails.url %}\n{% let name = hero._acssandboxustwo.nordstrom.productDetails.title %}\n{% let imageUrl = hero._acssandboxustwo.nordstrom.productDetails.primaryImageUrl %}\n{% let r = hero._acssandboxustwo.nordstrom.productDetails.productRating + 0.0 %}\n<!-- BEGIN HERO PRODUCT -->\n<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"border-collapse:collapse;\">\n<tr>\n<td width=\"300\" valign=\"top\" style=\"padding:0 20px 0 0;\">\n<a data-nl-type=\"DEEPLINK\" data-tracking-type=\"DEEPLINK\" href=\"{{{clickUrl}}}?{{{utmLinkParams}}}pd_hero\"><img width=\"300\" style=\"width:300px;max-width:100%;height:auto;display:block;\" alt=\"{{name}}\" src=\"{{{imageUrl}}}\"></a>\n</td>\n<td valign=\"top\" style=\"font-family:sans-serif;\">\n<!-- name --><p style=\"font-size:16px;font-weight:bold;color:#000000;margin:0 0 6px;\">{{name}}</p>\n<!-- price --><p style=\"font-size:15px;margin:0;\"><span style=\"color:#ff0000;font-weight:bold;\">${{{salePrice}}}</span> <span style=\"color:#000000;text-decoration:line-through;\">${{{wasPrice}}}</span></p>\n<!-- star rating -->{%#if r > 0.0 %}<p style=\"margin:6px 0;\">{% let starScale = [1, 2, 3, 4, 5] %}{{#each starScale as |i|}}{%#if r >= i %}<img width=\"14\" height=\"14\" data-medialibrary-id=\"urn:aaid:aem:afca9e01-bd6a-4d68-9fbb-a114dcb91ab3\" data-mediarepo-id=\"author-p69352-e612752.adobeaemcloud.com\" data-medialibrary-source=\"aem\" style=\"display:inline-block;width:14px;height:14px;\" alt=\"star\" src=\"images/star\">{%else if r >= i - 0.5 %}<img width=\"14\" height=\"14\" data-medialibrary-id=\"urn:aaid:aem:94d9c7aa-942c-41b1-95e5-dfdb3c6b11b6\" data-mediarepo-id=\"author-p69352-e612752.adobeaemcloud.com\" data-medialibrary-source=\"aem\" style=\"display:inline-block;width:14px;height:14px;\" alt=\"half star\" src=\"images/star\">{%else%}<img width=\"14\" height=\"14\" data-medialibrary-id=\"urn:aaid:aem:21e3fa17-feea-4927-86eb-8e30b518b619\" data-mediarepo-id=\"author-p69352-e612752.adobeaemcloud.com\" data-medialibrary-source=\"aem\" style=\"display:inline-block;width:14px;height:14px;\" alt=\"empty star\" src=\"images/star\">{%/if%}{{/each}}</p>{%/if%}\n<!-- CTA --><p style=\"margin:14px 0 0;\"><a data-nl-type=\"DEEPLINK\" data-tracking-type=\"DEEPLINK\" href=\"{{{clickUrl}}}?{{{utmLinkParams}}}pd_hero_cta\" style=\"display:inline-block;border:2px solid #272727;border-radius:15px;padding:9px 26px;font-family:sans-serif;font-size:16px;font-weight:bold;color:#272727;text-decoration:none;\">SHOP NOW</a></p>\n</td>\n</tr>\n</table>\n<!-- END HERO PRODUCT -->\n{{!-- ===== Execution metadata: log the shown hero SKU for reporting ===== --}}\n{{executionMetadata key=\"campaignId\" value=\"789708\"}}\n{{executionMetadata key=\"campaignType\" value=\"MARKETING_TRIGGERED\"}}\n{{executionMetadata key=\"skuIds\" value=bestSku}}\n{%/i