  "etag": "\"b5027fc6-0000-0200-0000-6a4aad600000\"",
  "fragment": {
    "content": "<div class=\"acr-fragment is-locked has-html-params\" data-fragment-id=\"ajo:5dce5a78-22c9-4a60-845d-b3a34e3f54f3\"><style acrite-mso-css=\"true\"></style><div class=\"acr-fragment acr-tmp-component\" data-tmp-component-id=\"html\" data-contenteditable=\"false\"><!-- BEGIN HERO -->\n{{!-- Hero product = first price-drop SKU from the trigger event; enriched via product-catalog dataset lookup; prices from the event payload --}}\n{% let pdMap = context.journey.events.`408257574`._acssandboxustwo.productTrigger.priceDropSKUs %}\n{% let heroSku = head(keys(pdMap)) %}\n{{datasetLookup datasetId=\"6a46945945b281e561cf5e27\" id=heroSku result=\"product\" required=false}}\n{% let pd = product._acssandboxustwo.nordstrom.productDetails %}\n{{!-- event payload value is \"sale|was\"; extract each side of the pipe via regex replace --}}\n{% let pair = get(pdMap, heroSku) %}\n{% let salePrice = replace(pair, \"[|].*\", \"\") %}\n{% let wasPrice = replace(pair, \".*[|]\", \"\") %}\n<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#ffffff;\">\n  <tr><td align=\"center\" style=\"padding:20px 20px 8px;font-family:Arial,Helvetica,sans-serif;font-size:20px;line-height:26px;color:#111111;font-weight:bold;\">Hurry! Your Shopping Bag item is on sale!</td></tr>\n  <tr><td align=\"center\" style=\"padding:0 20px 16px;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:20px;color:#333333;\">Shop now before it's gone.</td></tr>\n{%#if isNotNull(product) and pd.salabilityStatus = \"SELLABLE\" and pd.isShipAvailable = \"true\" and pd.isDeleted = \"N\" and pd.availableQuantity >= 1 %}\n  <tr><td align=\"center\" style=\"padding:0 20px 6px;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:18px;color:#111111;font-weight:bold;\">Back in stock&ndash; these deals won't last!</td></tr>\n  <!-- product image -->\n  <tr><td align=\"center\" style=\"padding:8px 20px 0;\"><a data-nl-type=\"DEEPLINK\" data-tracking-type=\"DEEPLINK\" href=\"{{{pd.url}}}?color={{{pd.color}}}&{{{utmLinkParams}}}pd_hero\" style=\"text-decoration:none;\"><img src=\"{{{pd.primaryImageUrl}}}\" alt=\"{{{pd.title}}}\" width=\"300\" style=\"display:block;width:300px;max-width:100%;height:auto;border:0;margin:0 auto;\"></a></td></tr>\n  <!-- brand -->\n  <tr><td align=\"center\" style=\"padding:14px 20px 0;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:18px;color:#111111;font-weight:bold;text-transform:uppercase;\">{{pd.label}}</td></tr>\n  <!-- Name -->\n  <tr><td align=\"center\" style=\"padding:4px 20px 0;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:20px;color:#333333;\">{{pd.title}}</td></tr>\n  {{!-- prices from event payload: salePrice = before pipe, wasPrice = after pipe --}}\n  <!-- Price -->\n  <tr><td align=\"center\" style=\"padding:8px 20px 0;font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:22px;color:#b00000;font-weight:bold;\">${{salePrice}} <span style=\"color:#767676;font-weight:normal;text-decoration:line-through;\">${{wasPrice}}</span></td></tr>\n  <!-- CTA Section -->\n  <tr><td align=\"center\" style=\"padding:16px 20px 24px;\"><a data-nl-type=\"DEEPLINK\" data-tracking-type=\"DEEPLINK\" href=\"{{{pd.url}}}?color={{{pd.color}}}&{{{utmLinkParams}}}pd_hero_cta\" style=\"display:inline-block;background-color:#111111;color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:44px;font-weight:bold;text-decoration:none;padding:0 40px;letter-spacing:1px;\">SHOP NOW</a></td></tr>\n{%else%}\n  {{!-- fallback when no eligible price-drop product resolves --}}\n  <tr><td align=\"center\" style=\"padding:8px 20px 24px;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:20px;color:#333333;\"><a data-nl-type=\"DEEPLINK\" data-tracking-type=\"DEEPLINK\" href=\"https://www.nordstrom.com/sale?{{{utmLinkParams}}}pd_hero_fallback\" style=\"color:#111111;font-weight:bold;\">Shop the latest markdowns</a></td></tr>\n{%/if%}\n</table>\n<!-- END HERO --></div></div>",
    "editorContext": {
